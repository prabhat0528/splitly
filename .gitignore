# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp compilation files (https://github.com/nodejs/node-gyp#frequently-asked-questions)
build/Release

# Parts of intermediate build files (e.g. parcel-bundler)
.cache
.parcel-cache

# Optional npm cache directory
.npm

# Output directory of Vite build
dist/
dist-ssr/
*.local

# Serverless directories
.serverless/

